---
import Layout from '@layouts/Layout.astro';
import SocialMediaBar from '@components/Others/SocialMediaBar.astro';
import Chatbot from '@components/Chat/Chatbot';
import SearchModal from '@components/Search/SearchModal';

import { getI18N } from '../i18n';

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const langPrefix = currentLocale === 'es' ? '' : `/${currentLocale}`;

const experiencia = [
  {
    rol: i18n.EXP_RIPNEL_ROLE,
    periodo: i18n.EXP_RIPNEL_PERIOD,
    logo: '🏢',
    bullets: [i18n.EXP_RIPNEL_1, i18n.EXP_RIPNEL_2, i18n.EXP_RIPNEL_3, i18n.EXP_RIPNEL_4],
  },
  {
    rol: i18n.EXP_TP_ROLE,
    periodo: i18n.EXP_TP_PERIOD,
    logo: '🎧',
    bullets: [i18n.EXP_TP_1, i18n.EXP_TP_2, i18n.EXP_TP_3, i18n.EXP_TP_4],
  },
];

const proyectos = [
  {
    titulo: i18n.PROJ_RIPNEL_TITLE,
    descripcion: i18n.PROJ_RIPNEL_DESC,
    resultado: i18n.PROJ_RIPNEL_RESULT,
    techs: i18n.PROJ_RIPNEL_TECHS,
    demo: i18n.PROJ_RIPNEL_DEMO,
    repo: i18n.PROJ_RIPNEL_REPO,
    icono: '⚙️',
    destacado: true,
  },
  {
    titulo: i18n.PROJ_ABOGADO_TITLE,
    descripcion: i18n.PROJ_ABOGADO_DESC,
    resultado: i18n.PROJ_ABOGADO_RESULT,
    techs: i18n.PROJ_ABOGADO_TECHS,
    demo: i18n.PROJ_ABOGADO_DEMO,
    repo: i18n.PROJ_ABOGADO_REPO,
    icono: '⚖️',
    destacado: false,
  },
  {
    titulo: i18n.PROJ_TP_TITLE,
    descripcion: i18n.PROJ_TP_DESC,
    resultado: i18n.PROJ_TP_RESULT,
    techs: i18n.PROJ_TP_TECHS,
    demo: i18n.PROJ_TP_DEMO,
    repo: i18n.PROJ_TP_REPO,
    icono: '📊',
    destacado: false,
  },
  {
    titulo: i18n.PROJ_DATA_TITLE,
    descripcion: i18n.PROJ_DATA_DESC,
    resultado: i18n.PROJ_DATA_RESULT,
    techs: i18n.PROJ_DATA_TECHS,
    demo: i18n.PROJ_DATA_DEMO,
    repo: i18n.PROJ_DATA_REPO,
    icono: '📈',
    destacado: false,
  },
];

const certs = [
  { titulo: i18n.CERT_GOOGLE_TITLE, desc: i18n.CERT_GOOGLE_DESC, icono: '📊' },
  { titulo: i18n.CERT_ORACLE_TITLE, desc: i18n.CERT_ORACLE_DESC, icono: '💻' },
  { titulo: i18n.CERT_IBM_TITLE, desc: i18n.CERT_IBM_DESC, icono: '📈' },
];
---

<Layout title={i18n.WEBPAGE_TITLE} description={i18n.HERO_H2}>

  <!-- ===== NAVBAR ===== -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-xl border-b border-magneto-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href={langPrefix} class="flex items-center gap-2 text-white font-display font-bold text-lg no-underline hover:text-magneto-400 transition-colors">
          <span class="text-magneto-500">&lt;</span>IM<span class="text-magneto-500">/&gt;</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden lg:flex items-center gap-1">
          <a href="#hero" class="px-3 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-surface-lighter">{i18n.NAV_HOME}</a>
          <a href="#about" class="px-3 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-surface-lighter">{i18n.NAV_ABOUT}</a>
          <a href="#experience" class="px-3 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-surface-lighter">{i18n.NAV_EXPERIENCE}</a>
          <a href="#skills" class="px-3 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-surface-lighter">{i18n.NAV_SKILLS}</a>
          <a href="#education" class="px-3 py-2 text-sm text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-surface-lighter">{i18n.NAV_EDUCATION}</a>
        </div>

        <div class="hidden lg:flex items-center gap-3">
          <button onclick="document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey:true, key:'k'}))" class="flex items-center gap-2 px-3 py-1.5 text-xs text-gray-500 bg-surface-lighter border border-magneto-800/40 rounded-lg hover:border-magneto-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span class="hidden xl:inline">Buscar</span>
            <kbd class="px-1.5 py-0.5 rounded bg-surface border border-magneto-800/50 text-[10px] font-mono">Ctrl K</kbd>
          </button>

          <div class="flex items-center gap-1 bg-surface-lighter rounded-lg p-1 border border-magneto-800/30">
            <a href="/" class={`px-2.5 py-1 text-xs rounded-md transition-colors no-underline ${currentLocale === 'es' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_ES}</a>
            <a href="/en" class={`px-2.5 py-1 text-xs rounded-md transition-colors no-underline ${currentLocale === 'en' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_EN}</a>
            <a href="/pt" class={`px-2.5 py-1 text-xs rounded-md transition-colors no-underline ${currentLocale === 'pt' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_PT}</a>
          </div>

          <a href="https://drive.google.com/file/d/1Mq81JtWl-iGLedp_v-1fTYPfWUHaA8o6/view?usp=sharing" target="_blank" class="ml-2 bg-magneto-600 hover:bg-magneto-500 text-white text-sm font-medium px-4 py-2 rounded-xl transition-all no-underline flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            CV
          </a>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden text-gray-400 hover:text-white p-2">
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-magneto-800/20 mt-1 pt-3 space-y-1">
        <a href="#hero" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_HOME}</a>
        <a href="#about" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_ABOUT}</a>
        <a href="#experience" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_EXPERIENCE}</a>
        <a href="#skills" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_SKILLS}</a>
        <a href="#education" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_EDUCATION}</a>
        <a href="#contact" class="block px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-surface-lighter rounded-lg no-underline">{i18n.NAV_CONTACT}</a>
        <div class="flex gap-2 px-3 pt-2">
          <a href="/" class={`px-3 py-1.5 text-xs rounded-md no-underline ${currentLocale === 'es' ? 'bg-magneto-700 text-white' : 'text-gray-400 bg-surface-lighter'}`}>{i18n.LANG_ES}</a>
          <a href="/en" class={`px-3 py-1.5 text-xs rounded-md no-underline ${currentLocale === 'en' ? 'bg-magneto-700 text-white' : 'text-gray-400 bg-surface-lighter'}`}>{i18n.LANG_EN}</a>
          <a href="/pt" class={`px-3 py-1.5 text-xs rounded-md no-underline ${currentLocale === 'pt' ? 'bg-magneto-700 text-white' : 'text-gray-400 bg-surface-lighter'}`}>{i18n.LANG_PT}</a>
        </div>
        <div class="px-3 pt-2">
          <a href="https://drive.google.com/file/d/1Qsd6dtd98VxcjC2jJy-4cGcVqtaDILqw/view?usp=sharing" target="_blank" class="block w-full text-center bg-magneto-600 hover:bg-magneto-500 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-all no-underline">
            📄 {i18n.NAV_CV}
          </a>
        </div>
      </div>
    </div>
  </nav>

  <script is:inline>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
    });
  </script>

  <!-- ===== HERO SECTION ===== -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-magneto-900/50 via-surface to-surface"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-magneto-700/20 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-magneto-600/50 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="flex justify-center mb-8">
        <img
          src="/profile.webp"
          alt={i18n.HERO_IMG_ALT}
          class="w-48 h-48 sm:w-56 sm:h-56 rounded-2xl border-2 border-magneto-600/40 shadow-2xl shadow-magneto-900/30 object-cover"
          width="224"
          height="224"
        />
      </div>

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-magneto-700/20 border border-magneto-600/30 text-magneto-300 text-sm mb-6 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        {i18n.HERO_BADGE}
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold text-white leading-tight mb-4 animate-fade-in delay-100">
        {i18n.HERO_H1}
      </h1>

      <p class="text-base sm:text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed mb-6 animate-fade-in delay-200">
        {i18n.HERO_H2}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in delay-300">
        <a href="#projects" class="inline-flex items-center gap-2 bg-gradient-to-r from-magneto-600 to-magneto-500 hover:from-magneto-500 hover:to-magneto-400 text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-magneto-700/30 hover:shadow-magneto-600/40 no-underline text-base">
          {i18n.HERO_CTA_PRIMARY}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <a href="https://drive.google.com/file/d/1Mq81JtWl-iGLedp_v-1fTYPfWUHaA8o6/view?usp=sharing" target="_blank" class="inline-flex items-center gap-2 border border-magneto-700/60 text-white font-medium px-8 py-3.5 rounded-xl hover:bg-magneto-900/40 transition-all no-underline text-base">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          {i18n.HERO_CTA_SECONDARY}
        </a>
      </div>

      <div class="mt-8 flex justify-center">
        <SocialMediaBar />
      </div>
    </div>
  </section>

  <!-- ===== ABOUT SECTION ===== -->
  <section id="about" class="py-8 sm:py-10 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.ABOUT_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3">{i18n.ABOUT_TITLE}</h2>
      </div>

      <div class="grid lg:grid-cols-5 gap-10 items-start">
        <div class="lg:col-span-3 space-y-5 text-gray-300 leading-relaxed text-base sm:text-lg">
          <p class="animate-on-scroll">{i18n.ABOUT_P1}</p>
          <p class="animate-on-scroll delay-200" set:html={i18n.ABOUT_P2}></p>
          <p class="animate-on-scroll delay-300" set:html={i18n.ABOUT_P3}></p>
        </div>

        <div class="lg:col-span-2 animate-on-scroll delay-300">
          <div class="bg-surface-light border border-magneto-800/30 rounded-2xl p-6 space-y-5">
            <h3 class="text-white font-display font-semibold text-lg flex items-center gap-2">
              <span class="text-2xl">🏃</span> {i18n.RUNNING_TITLE}
            </h3>
            <p class="text-gray-400 italic text-sm leading-relaxed border-l-2 border-magneto-600 pl-4">
              {i18n.RUNNING_QUOTE}
            </p>
            <p class="text-gray-500 text-sm">
              {i18n.RUNNING_DESC}
            </p>
            <div class="grid grid-cols-3 gap-3 pt-3">
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_1}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_1}</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_2}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_2}</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_3}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_3}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROFESSIONAL EXPERIENCE ===== -->
  <section id="experience" class="py-16 sm:py-20 px-4 sm:px-6 bg-surface-light/50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-5">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.EXPERIENCE_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3">{i18n.EXPERIENCE_TITLE}</h2>
        <p class="text-gray-500 text-sm mt-2">{i18n.EXPERIENCE_SUBTITLE}</p>
      </div>

      <div class="space-y-6 mt-8">
        {
          experiencia.map((exp) => (
            <div class="bg-surface border border-magneto-800/30 rounded-2xl p-6 sm:p-8 hover:border-magneto-700/40 transition-all animate-on-scroll">
              <div class="flex items-start gap-4 mb-5">
                <span class="text-3xl">{exp.logo}</span>
                <div class="flex-1">
                  <h3 class="text-xl font-display font-semibold text-white">{exp.rol}</h3>
                  <p class="text-magneto-400 text-sm">{exp.periodo}</p>
                </div>
              </div>
              <ul class="space-y-3">
                {exp.bullets.map((bullet: string) => (
                  <li class="flex items-start gap-3 text-gray-300 text-sm leading-relaxed">
                    <span class="text-magneto-500 mt-1 shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    </span>
                    {bullet}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== FEATURED PROJECTS ===== -->
  <section id="projects" class="py-8 sm:py-10 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.PROJECTS_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3">{i18n.PROJECTS_TITLE}</h2>
        <p class="text-gray-500 text-sm mt-2">{i18n.PROJECTS_SUBTITLE}</p>
      </div>

      <div class="space-y-6">
        {
          proyectos.map((proj) => (
            <div class={`bg-surface-light border rounded-2xl overflow-hidden transition-all hover:border-magneto-700/40 animate-on-scroll ${proj.destacado ? 'border-magneto-600/40 ring-1 ring-magneto-700/20' : 'border-magneto-800/20'}`}>
              {proj.destacado && (
                <div class="bg-gradient-to-r from-magneto-700 to-magneto-900 px-5 py-1.5 text-xs text-magneto-200 font-medium flex items-center gap-2">
                  <span>⭐</span> Projeto em destaque
                </div>
              )}
              <div class="p-6 sm:p-8">
                <div class="flex items-start gap-4 mb-4">
                  <span class="text-3xl">{proj.icono}</span>
                  <div class="flex-1">
                    <h3 class="text-xl font-display font-semibold text-white mb-2">{proj.titulo}</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-3">{proj.descripcion}</p>
                    <div class="bg-green-500/10 border border-green-500/20 rounded-xl px-4 py-3 mb-4">
                      <p class="text-green-400 text-sm font-medium flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        {proj.resultado}
                      </p>
                    </div>
                    <div class="flex flex-wrap gap-2 mb-5">
                      {proj.techs.split(' | ').map((tech: string) => (
                        <span class="px-2.5 py-1 text-xs rounded-lg bg-magneto-900/40 text-magneto-300 border border-magneto-800/40 font-mono">{tech}</span>
                      ))}
                    </div>
                    <div class="flex gap-4">
                      {proj.demo !== '#' && (
                        <a href={proj.demo} target="_blank" class="text-sm text-magneto-400 hover:text-magneto-300 font-medium no-underline flex items-center gap-1.5 transition-colors">
                          Live Demo <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                      )}
                      {proj.repo !== '#' && (
                        <a href={proj.repo} target="_blank" class="text-sm text-gray-500 hover:text-gray-300 font-medium no-underline flex items-center gap-1.5 transition-colors">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                          Repositório
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== SKILLS ===== -->
  <section id="skills" class="py-16 sm:py-20 px-4 sm:px-6 bg-surface-light/50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8">
