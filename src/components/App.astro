---
import Layout from '@layouts/Layout.astro';
import SearchModal from '@components/Search/SearchModal';
import SkillsUniverse, { type Skill, type TechNode } from '@components/Skills/SkillsUniverse';

import { getI18N } from '../i18n';

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const langPrefix = currentLocale === 'es' ? '' : `/${currentLocale}`;

const featuredText = currentLocale === 'en' ? 'Featured Project' : currentLocale === 'pt' ? 'Projeto em Destaque' : 'Proyecto Destacado';
const demoText = currentLocale === 'en' ? 'Live Demo' : currentLocale === 'pt' ? 'Demo ao Vivo' : 'Live Demo';
const repoText = currentLocale === 'en' ? 'Repository' : currentLocale === 'pt' ? 'Repositório' : 'Repositorio';

const experiencia = [
  {
    rol: i18n.EXP_RIPNEL_ROLE,
    periodo: i18n.EXP_RIPNEL_PERIOD,
    bullets: [i18n.EXP_RIPNEL_1, i18n.EXP_RIPNEL_2, i18n.EXP_RIPNEL_3, i18n.EXP_RIPNEL_4],
  },
  {
    rol: i18n.EXP_TP_ROLE,
    periodo: i18n.EXP_TP_PERIOD,
    bullets: [i18n.EXP_TP_1, i18n.EXP_TP_2, i18n.EXP_TP_3, i18n.EXP_TP_4],
  },
];

const proyectos = [
  {
    titulo: i18n.PROJ_RIPNEL_TITLE,
    problema: i18n.PROJ_RIPNEL_PROBLEM,
    descripcion: i18n.PROJ_RIPNEL_DESC,
    resultado: i18n.PROJ_RIPNEL_RESULT,
    techs: i18n.PROJ_RIPNEL_TECHS,
    imagen: i18n.PROJ_RIPNEL_IMAGE,
    demo: i18n.PROJ_RIPNEL_DEMO,
    repo: i18n.PROJ_RIPNEL_REPO,
    destacado: true,
  },
  {
    titulo: i18n.PROJ_COMMERCIAL_BI_TITLE,
    problema: i18n.PROJ_COMMERCIAL_BI_PROBLEM,
    descripcion: i18n.PROJ_COMMERCIAL_BI_DESC,
    resultado: i18n.PROJ_COMMERCIAL_BI_RESULT,
    techs: i18n.PROJ_COMMERCIAL_BI_TECHS,
    imagen: i18n.PROJ_COMMERCIAL_BI_IMAGE,
    demo: i18n.PROJ_COMMERCIAL_BI_DEMO,
    repo: i18n.PROJ_COMMERCIAL_BI_REPO,
    destacado: false,
  },
  {
    titulo: i18n.PROJ_CX_METRICS_TITLE,
    problema: i18n.PROJ_CX_METRICS_PROBLEM,
    descripcion: i18n.PROJ_CX_METRICS_DESC,
    resultado: i18n.PROJ_CX_METRICS_RESULT,
    techs: i18n.PROJ_CX_METRICS_TECHS,
    imagen: i18n.PROJ_CX_METRICS_IMAGE,
    demo: i18n.PROJ_CX_METRICS_DEMO,
    repo: i18n.PROJ_CX_METRICS_REPO,
    destacado: false,
  },
  {
    titulo: i18n.PROJ_SOCIAL_EDA_TITLE,
    problema: i18n.PROJ_SOCIAL_EDA_PROBLEM,
    descripcion: i18n.PROJ_SOCIAL_EDA_DESC,
    resultado: i18n.PROJ_SOCIAL_EDA_RESULT,
    techs: i18n.PROJ_SOCIAL_EDA_TECHS,
    imagen: i18n.PROJ_SOCIAL_EDA_IMAGE,
    demo: i18n.PROJ_SOCIAL_EDA_DEMO,
    repo: i18n.PROJ_SOCIAL_EDA_REPO,
    destacado: false,
  },
  {
    titulo: i18n.PROJ_LAW_FIRM_TITLE,
    problema: i18n.PROJ_LAW_FIRM_PROBLEM,
    descripcion: i18n.PROJ_LAW_FIRM_DESC,
    resultado: i18n.PROJ_LAW_FIRM_RESULT,
    techs: i18n.PROJ_LAW_FIRM_TECHS,
    imagen: i18n.PROJ_LAW_FIRM_IMAGE,
    demo: i18n.PROJ_LAW_FIRM_DEMO,
    repo: i18n.PROJ_LAW_FIRM_REPO,
    destacado: false,
  },
];

const generateTechNodes = (
  items: string,
  category: 'frontend' | 'data' | 'tools',
  centerX: number,
  centerY: number,
  spreadX: number,
  spreadY: number
): TechNode[] => {
  const techs = items.split(' | ');
  return techs.map((name, i) => {
    const angle = (i / techs.length) * Math.PI * 2;
    const r = 0.45 + 0.55 * ((i % 3) / 2);
    return {
      name,
      category,
      x: Math.max(3, Math.min(97, centerX + spreadX * r * Math.cos(angle))),
      y: Math.max(5, Math.min(95, centerY + spreadY * r * Math.sin(angle))),
    };
  });
};

const techNodes: TechNode[] = [
  ...generateTechNodes(i18n.SKILLS_FRONTEND_ITEMS, 'frontend', 15, 20, 10, 13),
  ...generateTechNodes(i18n.SKILLS_DATA_ITEMS, 'data', 82, 20, 10, 13),
  ...generateTechNodes(i18n.SKILLS_TOOLS_ITEMS, 'tools', 50, 88, 28, 5),
];

const skillsData: Skill[] = [
  { id: 1, name: i18n.SKILL_1_NAME, state: 'improved', scenario: i18n.SKILL_1_SCENARIO, description: i18n.SKILL_1_DESC, link: '#experience', x: 20, y: 42, size: 'large' },
  { id: 2, name: i18n.SKILL_2_NAME, state: 'improved', scenario: i18n.SKILL_2_SCENARIO, description: i18n.SKILL_2_DESC, link: '#education', x: 78, y: 40, size: 'normal' },
  { id: 3, name: i18n.SKILL_3_NAME, state: 'improving', scenario: i18n.SKILL_3_SCENARIO, description: i18n.SKILL_3_DESC, link: 'https://www.linkedin.com/in/ivan-daniel-manrique-roa-978a29187', x: 50, y: 70, size: 'normal' },
  { id: 4, name: i18n.SKILL_4_NAME, state: 'improved', scenario: i18n.SKILL_4_SCENARIO, description: i18n.SKILL_4_DESC, link: '#about', x: 12, y: 65, size: 'normal' },
  { id: 5, name: i18n.SKILL_5_NAME, state: 'improved', scenario: i18n.SKILL_5_SCENARIO, description: i18n.SKILL_5_DESC, link: '#projects', x: 72, y: 55, size: 'large' },
  { id: 6, name: i18n.SKILL_6_NAME, state: 'improving', scenario: i18n.SKILL_6_SCENARIO, description: i18n.SKILL_6_DESC, link: 'https://www.linkedin.com/in/ivan-daniel-manrique-roa-978a29187', x: 90, y: 68, size: 'normal' },
  { id: 7, name: i18n.SKILL_7_NAME, state: 'improved', scenario: i18n.SKILL_7_SCENARIO, description: i18n.SKILL_7_DESC, link: '#experience', x: 48, y: 38, size: 'large' },
  { id: 8, name: i18n.SKILL_8_NAME, state: 'improved', scenario: i18n.SKILL_8_SCENARIO, description: i18n.SKILL_8_DESC, link: '#experience', x: 38, y: 58, size: 'normal' },
];

const certs = [
  { titulo: i18n.CERT_IBM_TITLE, desc: i18n.CERT_IBM_DESC },
  { titulo: i18n.CERT_GOOGLE_TITLE, desc: i18n.CERT_GOOGLE_DESC },
  { titulo: i18n.CERT_ORACLE_TITLE, desc: i18n.CERT_ORACLE_DESC },
];

const dockItems = [
  { id: 'hero', label: i18n.NAV_HOME },
  { id: 'about', label: i18n.NAV_ABOUT },
  { id: 'education', label: i18n.NAV_EDUCATION },
  { id: 'experience', label: i18n.NAV_EXPERIENCE },
  { id: 'projects', label: i18n.PROJECTS_TITLE },
  { id: 'skills', label: i18n.NAV_SKILLS_MAP },
  { id: 'contact', label: i18n.NAV_CONTACT },
];
---

<Layout title={i18n.WEBPAGE_TITLE} description={i18n.HERO_H2}>

  <!-- ===== TOP BAR (minimal) ===== -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-surface/90 backdrop-blur-xl border-b border-magneto-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <a href={langPrefix} class="flex items-center gap-2 text-white font-display font-bold text-lg no-underline hover:text-magneto-400 transition-colors">
          <span class="text-magneto-500">&lt;</span>IM<span class="text-magneto-500">/&gt;</span>
        </a>

        <div class="flex items-center gap-3">
          <button onclick="document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey:true, key:'k'}))" class="flex items-center gap-2 px-3 py-1.5 text-xs text-gray-500 bg-surface-lighter border border-magneto-800/40 rounded-md hover:border-magneto-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span class="hidden xl:inline">Buscar</span>
            <kbd class="px-1.5 py-0.5 rounded bg-surface border border-magneto-800/50 text-[10px] font-mono">Ctrl K</kbd>
          </button>

          <div class="flex items-center gap-1 bg-surface-lighter rounded-md p-1 border border-magneto-800/30">
            <a href="/" class={`px-2.5 py-1 text-xs rounded transition-colors no-underline ${currentLocale === 'es' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_ES}</a>
            <a href="/en" class={`px-2.5 py-1 text-xs rounded transition-colors no-underline ${currentLocale === 'en' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_EN}</a>
            <a href="/pt" class={`px-2.5 py-1 text-xs rounded transition-colors no-underline ${currentLocale === 'pt' ? 'bg-magneto-700 text-white' : 'text-gray-400 hover:text-white'}`}>{i18n.LANG_PT}</a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ===== HERO SECTION ===== -->
  <section id="hero" class="relative overflow-hidden pt-14 border-b border-magneto-800/40">
    <div class="absolute inset-0 bg-surface"></div>
    <div class="absolute top-1/2 left-1/4 -translate-x-1/2 w-[400px] h-[400px] bg-magneto-800/15 rounded-full blur-[100px]"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6" style="padding-top: 70px; padding-bottom: 70px;">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">

        <!-- Left Column: Name + Description + CV -->
        <div class="flex flex-col justify-center animate-fade-in">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-white leading-tight tracking-tight mb-4">
            {i18n.HERO_NAME}
          </h1>

          <p class="text-[10px] sm:text-xs lg:text-sm text-gray-400 max-w-lg leading-relaxed mb-6">
            {i18n.HERO_H2}
          </p>

          <div class="mb-6">
            <a href="https://drive.google.com/file/d/1Mq81JtWl-iGLedp_v-1fTYPfWUHaA8o6/view?usp=sharing" target="_blank" class="inline-flex items-center gap-2 bg-magneto-600 hover:bg-magneto-500 text-white text-sm font-medium px-5 py-2.5 rounded-md transition-all no-underline">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {i18n.HERO_CTA_SECONDARY}
            </a>
          </div>
        </div>

        <!-- Right Column: Large Photo in Contrasting Frame -->
        <div class="flex justify-center lg:justify-end animate-fade-in delay-200">
          <div class="relative">
            <div class="bg-magneto-700/10 border-2 border-magneto-600/30 rounded-lg p-3 shadow-xl shadow-black/30">
              <img
                src="/profile.webp"
                alt={i18n.HERO_IMG_ALT}
                class="w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96 object-cover rounded-md"
                width="384"
                height="384"
              />
            </div>
            <div class="absolute -inset-1 bg-magneto-600/10 rounded-lg -z-10 blur-md"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== ABOUT SECTION ===== -->
  <section id="about" class="py-12 px-4 sm:px-6 border-t border-magneto-800/30">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.ABOUT_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3 tracking-tight">{i18n.ABOUT_TITLE}</h2>
      </div>

      <div class="grid lg:grid-cols-5 gap-10 items-start">
        <div class="lg:col-span-3 space-y-5 text-gray-300 leading-relaxed text-base sm:text-lg">
          <p class="animate-on-scroll">{i18n.ABOUT_P1}</p>
          <p class="animate-on-scroll delay-200" set:html={i18n.ABOUT_P2}></p>
          <p class="animate-on-scroll delay-300" set:html={i18n.ABOUT_P3}></p>
        </div>

        <div class="lg:col-span-2 animate-on-scroll delay-300">
          <div class="bg-surface-light border border-magneto-800/40 rounded-lg p-6 space-y-5 shadow-lg shadow-black/10">
            <h3 class="text-white font-display font-semibold text-lg flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-magneto-400"><path d="M21 15.5a9 9 0 0 1-9 9 9 9 0 0 1-9-9c0-2.5 1-4.5 2.5-6L12 3l6.5 6.5c1.5 1.5 2.5 3.5 2.5 6z"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
              {i18n.RUNNING_TITLE}
            </h3>
            <p class="text-gray-400 italic text-sm leading-relaxed border-l-2 border-magneto-600 pl-4">
              {i18n.RUNNING_QUOTE}
            </p>
            <p class="text-gray-500 text-sm">
              {i18n.RUNNING_DESC}
            </p>
            <div class="grid grid-cols-3 gap-3 pt-3 border-t border-magneto-800/30">
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_1}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_1}</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_2}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_2}</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-display font-bold text-magneto-400">{i18n.RUNNING_STATS_3}</div>
                <div class="text-xs text-gray-500 mt-1">{i18n.RUNNING_LABEL_3}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EDUCATION & ACHIEVEMENTS ===== -->
  <section id="education" class="py-12 px-4 sm:px-6 bg-surface-light/30 border-t border-magneto-800/30">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.EDUCATION_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3 tracking-tight">{i18n.EDUCATION_TITLE}</h2>
      </div>

      <div class="space-y-4 mb-12">
        <div class="bg-surface border border-magneto-800/40 rounded-lg p-6 sm:p-8 flex flex-col sm:flex-row items-start gap-5 hover:border-magneto-700/50 transition-all duration-200 shadow-sm shadow-black/10 animate-on-scroll">
          <div class="w-12 h-12 rounded-md bg-magneto-700/20 border border-magneto-700/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-magneto-400"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <div class="flex-1">
            <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
              <h3 class="text-xl font-display font-semibold text-white">{i18n.EDUCATION_UTP_TITLE}</h3>
              <span class="px-2.5 py-0.5 text-xs rounded bg-green-500/15 text-green-400 border border-green-500/20 w-fit">{i18n.EDUCATION_UTP_STATUS}</span>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">{i18n.EDUCATION_UTP_DESC}</p>
          </div>
        </div>

        <div class="bg-surface border border-magneto-800/40 rounded-lg p-6 sm:p-8 flex flex-col sm:flex-row items-start gap-5 hover:border-magneto-700/50 transition-all duration-200 shadow-sm shadow-black/10 animate-on-scroll delay-200">
          <div class="w-12 h-12 rounded-md bg-magneto-700/20 border border-magneto-700/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-magneto-400"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          </div>
          <div class="flex-1">
            <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
              <h3 class="text-xl font-display font-semibold text-white">{i18n.EDUCATION_IMPULSA_TITLE}</h3>
              <span class="px-2.5 py-0.5 text-xs rounded bg-amber-500/15 text-amber-400 border border-amber-500/20 w-fit">{i18n.EDUCATION_IMPULSA_STATUS}</span>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">{i18n.EDUCATION_IMPULSA_DESC}</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-xl font-display font-bold text-white mb-6 tracking-tight">{i18n.CERTIFICATIONS_TITLE}</h3>
        <div class="grid sm:grid-cols-3 gap-5">
          {certs.map((cert) => (
            <div class="bg-surface border border-magneto-800/40 rounded-lg p-5 hover:border-magneto-700/50 transition-all duration-200 shadow-sm shadow-black/10 animate-on-scroll">
              <h4 class="text-sm font-semibold text-white mb-2">{cert.titulo}</h4>
              <p class="text-xs text-gray-500 leading-relaxed">{cert.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROFESSIONAL EXPERIENCE ===== -->
  <section id="experience" class="py-12 px-4 sm:px-6 border-t border-magneto-800/30">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.EXPERIENCE_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3 tracking-tight">{i18n.EXPERIENCE_TITLE}</h2>
        <p class="text-gray-500 text-sm mt-2">{i18n.EXPERIENCE_SUBTITLE}</p>
      </div>

      <div class="space-y-6">
        {
          experiencia.map((exp) => (
            <div class="bg-surface border border-magneto-800/40 rounded-lg p-6 sm:p-8 hover:border-magneto-700/50 transition-all duration-200 shadow-sm shadow-black/10 animate-on-scroll">
              <div class="mb-5">
                <h3 class="text-xl font-display font-semibold text-white">{exp.rol}</h3>
                <p class="text-magneto-400 text-sm mt-1">{exp.periodo}</p>
              </div>
              <ul class="space-y-3">
                {exp.bullets.map((bullet: string) => (
                  <li class="flex items-start gap-3 text-gray-300 text-sm leading-relaxed">
                    <span class="text-magneto-500 mt-1 shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    {bullet}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== PROJECTS (Case Study, Alternating, Bilingual) ===== -->
  <section id="projects" class="py-12 px-4 sm:px-6 border-t border-magneto-800/30">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <span class="text-magneto-400 text-sm font-mono uppercase tracking-widest">// {i18n.PROJECTS_TITLE}</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-3 tracking-tight">{i18n.PROJECTS_TITLE}</h2>
        <p class="text-gray-500 text-sm mt-2">{i18n.PROJECTS_SUBTITLE}</p>
      </div>

      <div class="space-y-12">
        {
          proyectos.map((proj, index) => (
            <div class={`flex flex-col lg:flex-row gap-8 lg:gap-12 items-center animate-on-scroll ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
              {/* Image */}
              <div class="w-full lg:w-[42%] shrink-0">
                <div class="aspect-[4/3] bg-surface-lighter border border-magneto-800/40 rounded-lg overflow-hidden flex items-center justify-center relative shadow-sm shadow-black/10">
                  <img
                    src={proj.imagen}
                    alt={proj.titulo}
                    class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  />
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <span class="text-gray-600 text-sm font-mono">{proj.imagen.split('/').pop()}</span>
                  </div>
                </div>
              </div>

              {/* Case Study */}
              <div class="w-full lg:w-[58%]">
                {proj.destacado && (
                  <span class="inline-block text-xs font-mono uppercase tracking-wide px-2.5 py-1 rounded bg-magneto-700/30 text-magneto-300 border border-magneto-600/30 mb-3">
                    ★ {featuredText}
                  </span>
                )}
                <h3 class="text-xl sm:text-2xl font-display font-semibold text-white mb-5 tracking-tight leading-snug">{proj.titulo}</h3>

                {/* Problem */}
                <div class="border-l-2 border-amber-500/50 bg-amber-500/5 pl-4 py-2.5 mb-4 rounded-r">
                  <span class="text-[10px] text-amber-400 font-mono uppercase tracking-widest block mb-1">{i18n.PROJECTS_LABEL_PROBLEM}</span>
                  <p class="text-gray-400 text-sm leading-relaxed">{proj.problema}</p>
                </div>

                {/* Description */}
                <p class="text-gray-400 text-sm leading-relaxed mb-5">{proj.descripcion}</p>

                {/* Stack */}
                <div class="mb-5">
                  <span class="text-[10px] text-magneto-400 font-mono uppercase tracking-widest block mb-2">{i18n.PROJECTS_LABEL_STACK}</span>
                  <div class="flex flex-wrap gap-2">
                    {proj.techs.split(' | ').map((tech: string) => (
                      <span class="px-2.5 py-1 text-xs rounded bg-magneto-900/40 text-magneto-300 border border-magneto-800/40 font-mono transition-colors hover:border-magneto-600/50">{tech}</span>
                    ))}
                  </div>
                </div>

                {/* Result */}
                <div class="border-l-2 border-cyan-500/50 bg-cyan-500/5 pl-4 py-2.5 mb-5 rounded-r">
                  <span class="text-[10px] text-cyan-400 font-mono uppercase tracking-widest block mb-1">{i18n.PROJECTS_LABEL_RESULT}</span>
                  <p class="text-cyan-300 text-sm font-medium flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {proj.resultado}
                  </p>
                </div>

                {/* Links */}
                <div class="flex gap-5">
                  {proj.demo !== '#' && (
                    <a href={proj.demo} target="_blank" class="text-sm text-magneto-400 hover:text-magneto-300 font-medium no-underline flex items-center gap-1.5 transition-colors">
                      {demoText}
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  )}
                  {proj.repo !== '#' && (
                    <a href={proj.repo} target="_blank" class="text-sm text-gray-500 hover:text-gray-300 font-medium no-underline flex items-center gap-1.5 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                      {repoText}
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== SKILLS UNIVERSE (Habilidades & Tecnologías) ===== -->
